{
  "name": "onlyvoices",
  "version": "1.0.0",
  "description": "OnlyVoices - Your Audiobooks, Your Voices",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:api\"",
    "dev:vite": "vite",
    "dev:api": "cross-env IS_OFFLINE=true STAGE=local nodemon --watch server --watch api --watch utils --ext js server/local-api-server.js",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:frontend": "npm run build && aws s3 sync dist/ s3://onlyvoices.ai --delete"
  },
  "dependencies": {
    "aws-sdk": "^2.1693.0",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.6.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "express": "^4.18.2",
    "nodemon": "^3.1.11",
    "vite": "^5.0.0"
  }
}
